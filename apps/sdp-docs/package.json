{
  "name": "sdp-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:local": "node scripts/dev.mjs",
    "build": "pnpm generate:api && pnpm generate:ai && pnpm generate:source && next build",
    "start": "next start --port 3001",
    "pretypecheck": "pnpm generate:source",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "generate:api": "pnpm -C ../sdp-api run openapi:generate && node scripts/generate-api-docs.mjs && node scripts/generate-postman-collection.mjs && pnpm exec biome check --write content/docs/meta.json content/docs/reference/api/meta.json",
    "generate:ai": "tsx scripts/generate-ai-resources.ts",
    "generate:source": "node scripts/generate-source.mjs",
    "check:links": "tsx scripts/check-links.ts",
    "watch:source": "node scripts/watch-source.mjs"
  },
  "dependencies": {
    "@sdp/env-config": "workspace:*",
    "@sdp/types": "workspace:*",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.11",
    "fumadocs-ui": "^16.9.3",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "4.22.4",
    "typescript": "^6.0.3"
  }
}
