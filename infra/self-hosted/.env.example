# Self-hosted Solana Developer Platform. Copy to .env and fill in.
# Used for compose interpolation (image tag, ports) and loaded into sdp-api as its
# runtime env; web/docs receive only the NEXT_PUBLIC_* values set in compose.yml.

# Image source — pin SDP_VERSION to a release tag for reproducible deploys.
SDP_IMAGE_REGISTRY=ghcr.io/solana-foundation/sdp
SDP_VERSION=latest

# Host ports
SDP_API_PORT=8787
SDP_WEB_PORT=3000
SDP_DOCS_PORT=3001

# Core runtime
ENVIRONMENT=production
SDP_DEPLOYMENT_MODE=self_hosted

# Database & cache. DATABASE_URL is derived from POSTGRES_* for the bundled
# Postgres; set DATABASE_URL explicitly to point at an external database.
# Generate with `openssl rand -hex 32` (hex is URL-safe, no encoding needed).
POSTGRES_DB=sdp
POSTGRES_USER=sdp
POSTGRES_PASSWORD=
# DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://redis:6379

# App secrets — generate with `openssl rand -hex 32`.
API_KEY_PEPPER=
CUSTODY_ENCRYPTION_KEY=

# Public URLs (browser-facing), applied to the web/docs bundles at container start.
# Use base origins (scheme + host[:port]), no trailing path.
NEXT_PUBLIC_SDP_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_SDP_API_URL=http://localhost:8787
NEXT_PUBLIC_SDP_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SDP_DOCS_URL=http://localhost:3001
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Authentication (Clerk) — required.
# See apps/sdp-api/docs/self-hosting/clerk-setup.md for full walkthrough.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk issuer — shown in Clerk Dashboard under API Keys → JWT Templates.
# Looks like https://<slug>.clerk.accounts.dev for dev instances.
CLERK_ISSUER=

# JWT template name — must match the template created in Clerk Dashboard (step 3).
CLERK_JWT_TEMPLATE=sdp-api

# Clerk webhook signing secret — required for auto-provisioning organizations.
# Get from Clerk Dashboard → Webhooks → your endpoint → Signing Secret.
# Without this, organizations must be inserted into the DB manually.
# CLERK_WEBHOOK_SECRET=whsec_...

# Solana RPC
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Signing provider — local keeps keys in this deployment; managed backends need their own env.
SIGNING_PROVIDER=local
# Base58 keypair the local signer uses to sign transactions. Generate one and fund it.
CUSTODY_PRIVATE_KEY=

# Fee payment — native pays from FEE_PAYER_PRIVATE_KEY (falls back to CUSTODY_PRIVATE_KEY);
# kora delegates to a Kora node.
FEE_PAYMENT_PROVIDER=native
# Optional dedicated fee payer; defaults to CUSTODY_PRIVATE_KEY when blank.
# FEE_PAYER_PRIVATE_KEY=

# Recurring payments (disabled by default)
PAYMENTS_RECURRING_ENABLED=false

# Observability (optional)
# SENTRY_DSN=

# Provider co-signers and automation should be hosted outside the default compose
# stack; see /docs/self-hosting/external-co-signers and infra/utila/cloud-run.
# Other optional integrations (compliance, fiat ramps, more signing backends) use
# the same mechanism; see the self-hosting docs.
