{
  "receiver": "slack",
  "group_by": ["grafana_folder", "alertname", "service"],
  "group_wait": "30s",
  "group_interval": "5m",
  "repeat_interval": "4h",
  "routes": [
    {
      "receiver": "pagerduty",
      "object_matchers": [["pagerduty", "=", "true"]],
      "continue": true,
      "group_wait": "30s",
      "group_interval": "5m",
      "repeat_interval": "4h"
    },
    {
      "receiver": "slack",
      "object_matchers": [["slack", "=", "true"]],
      "group_wait": "30s",
      "group_interval": "5m",
      "repeat_interval": "4h"
    }
  ]
}
