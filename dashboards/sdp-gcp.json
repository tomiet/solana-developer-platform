{
  "uid": "sdp-gcp",
  "title": "GCP stats",
  "description": "GCP Cloud Run health for all Solana Developer Platform services (kora-mainnet, kora-devnet, kora-sdp, bvnk-proxy-dev, sdp-collector, utila-cosigner). Sourced from Cloud Monitoring run.googleapis.com/* metrics via the sdp-gcm (stackdriver) datasource. Use the service_name variable (top-left) to filter.",
  "tags": ["sdp", "gcp", "cloud-run"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service_name",
        "label": "service",
        "type": "custom",
        "query": "kora-mainnet,kora-devnet,kora-sdp,bvnk-proxy-dev,sdp-collector,utila-cosigner",
        "refresh": 0,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": ["All"],
          "value": ["$__all"],
          "selected": true
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "kora-mainnet",
            "value": "kora-mainnet",
            "selected": false
          },
          {
            "text": "kora-devnet",
            "value": "kora-devnet",
            "selected": false
          },
          {
            "text": "kora-sdp",
            "value": "kora-sdp",
            "selected": false
          },
          {
            "text": "bvnk-proxy-dev",
            "value": "bvnk-proxy-dev",
            "selected": false
          },
          {
            "text": "sdp-collector",
            "value": "sdp-collector",
            "selected": false
          },
          {
            "text": "utila-cosigner",
            "value": "utila-cosigner",
            "selected": false
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Traffic & latency",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests (2xx)",
      "description": "run.googleapis.com/request_count filtered to response_code_class = 2xx, grouped by service_name. Only services receiving HTTP traffic report this (kora-*, bvnk-proxy-dev).",
      "datasource": {
        "type": "stackdriver",
        "uid": "sdp-gcm"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "stackdriver",
            "uid": "sdp-gcm"
          },
          "queryType": "timeSeriesList",
          "timeSeriesList": {
            "projectName": "solana-developer-platform",
            "filters": [
              "metric.type",
              "=",
              "run.googleapis.com/request_count",
              "AND",
              "resource.label.service_name",
              "=~",
              "${service_name:regex}",
              "AND",
              "metric.label.response_code_class",
              "=",
              "2xx"
            ],
            "groupBys": ["resource.label.service_name", "metric.label.response_code_class"],
            "crossSeriesReducer": "REDUCE_SUM",
            "perSeriesAligner": "ALIGN_DELTA",
            "alignmentPeriod": "60s"
          },
          "aliasBy": "{{resource.label.service_name}} {{metric.label.response_code_class}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Errors (4xx/5xx)",
      "description": "run.googleapis.com/request_count filtered to response_code_class = 4xx or 5xx, grouped by service_name. Only services receiving HTTP traffic report this (kora-*, bvnk-proxy-dev). No series means no client/server errors in range.",
      "datasource": {
        "type": "stackdriver",
        "uid": "sdp-gcm"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "stackdriver",
            "uid": "sdp-gcm"
          },
          "queryType": "timeSeriesList",
          "timeSeriesList": {
            "projectName": "solana-developer-platform",
            "filters": [
              "metric.type",
              "=",
              "run.googleapis.com/request_count",
              "AND",
              "resource.label.service_name",
              "=~",
              "${service_name:regex}",
              "AND",
              "metric.label.response_code_class",
              "=~",
              "(4xx|5xx)"
            ],
            "groupBys": ["resource.label.service_name", "metric.label.response_code_class"],
            "crossSeriesReducer": "REDUCE_SUM",
            "perSeriesAligner": "ALIGN_DELTA",
            "alignmentPeriod": "60s"
          },
          "aliasBy": "{{resource.label.service_name}} {{metric.label.response_code_class}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request latency p50",
      "description": "run.googleapis.com/request_latencies (DELTA distribution), 50th percentile per series (ALIGN_PERCENTILE_50), by service. Only HTTP services report this (kora-*, bvnk-proxy-dev).",
      "datasource": {
        "type": "stackdriver",
        "uid": "sdp-gcm"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "stackdriver",
            "uid": "sdp-gcm"
          },
