{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.*"],
  "globalEnv": [
    "API_KEY_PEPPER",
    "CLERK_AUDIENCE",
    "CLERK_API_URL",
    "CLERK_ISSUER",
    "CLERK_JWT_TEMPLATE",
    "CLERK_JWKS_URL",
    "CLERK_SECRET_KEY",
    "CLERK_WEBHOOK_SECRET",
    "CUSTODY_PRIVATE_KEY",
    "KORA_API_KEY",
    "KORA_MIN_BALANCE_LAMPORTS",
    "KORA_RPC_URL",
    "KORA_TIMEOUT_MS",
    "CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE",
    "DATABASE_URL",
    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_CLERK_JWT_TEMPLATE",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL",
    "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
    "NEXT_PUBLIC_SDP_API_URL",
    "NEXT_PUBLIC_SDP_DOCS_URL",
    "NEXT_PUBLIC_SDP_WEB_URL",
    "NEXT_PUBLIC_SDP_API_BASE_URL",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_SOLANA_NETWORK",
    "PLAYWRIGHT_API_PERSIST_PATH",
    "PLAYWRIGHT_API_PORT",
    "PLAYWRIGHT_API_URL",
    "PLAYWRIGHT_BASE_URL",
    "PLAYWRIGHT_NEXT_DIST_DIR",
    "PLAYWRIGHT_USE_NEXT_START",
    "PRIVY_API_BASE_URL",
    "PRIVY_APP_ID",
    "PRIVY_APP_SECRET",
    "PRIVY_REQUEST_DELAY_MS",
    "PRIVY_WALLET_ID",
    "REDIS_URL",
    "RUN_INTEGRATION_TESTS",
    "SDP_API_BASE_URL",
    "SDP_API_LOCAL_PERSIST_PATH",
    "SDP_API_PORT",
    "SDP_API_RESET_LOCAL_STATE",
    "SDP_DOCS_PROXY_ORIGIN",
    "SDP_RUNTIME",
    "SOLANA_NETWORK",
    "SOLANA_RPC_ALCHEMY_API_KEY",
    "SOLANA_RPC_ALCHEMY_URL",
    "SOLANA_RPC_HELIUS_API_KEY",
    "SOLANA_RPC_HELIUS_URL",
    "SOLANA_RPC_QUICKNODE_API_KEY",
    "SOLANA_RPC_QUICKNODE_URL",
    "SOLANA_RPC_TRITON_API_KEY",
    "SOLANA_RPC_TRITON_URL",
    "SOLANA_RPC_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:local": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
